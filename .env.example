# apps/platform (client-side, exposed to the browser via Vite's VITE_ prefix)
# Find these in your Supabase project: Settings -> API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# NOTE: OPENROUTER_API_KEY and OPENROUTER_MODEL are NOT set here.
# They are server-side secrets for the process-image Edge Function only:
#   supabase secrets set OPENROUTER_API_KEY=sk-or-... OPENROUTER_MODEL=google/gemini-2.0-flash-001

