# apps/platform and apps/vocab (client-side, exposed to the browser via Vite's VITE_ prefix)
# Find these in your Supabase project: Settings -> API. Both apps share the same
# Supabase project for silent/anonymous auth, and apps/vocab reads/writes its data
# straight from Supabase Postgres (via supabase-js + RLS) -- no separate backend.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# NOTE: the following are NOT set here. They are server-side secrets for Edge
# Functions only, set via `supabase secrets set ...`:
#   OPENROUTER_API_KEY, OPENROUTER_MODEL     - process-image function
#   SUPABASE_SERVICE_ROLE_KEY                - submit-quiz function (needed to read
#                                               quiz_options.is_correct, which RLS
#                                               otherwise hides from every client)
# SUPABASE_URL and SUPABASE_ANON_KEY are already available to Edge Functions
# automatically -- no need to set those as secrets.
