# apps/platform and apps/vocab (client-side, exposed to the browser via Vite's VITE_ prefix)
# Find these in your Supabase project: Settings -> API. Both apps share the same
# Supabase project for silent/anonymous auth.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# apps/vocab only: base URL of apps/api
VITE_API_URL=http://localhost:8000

# NOTE: OPENROUTER_API_KEY and OPENROUTER_MODEL are NOT set here.
# They are server-side secrets for the process-image Edge Function only:
#   supabase secrets set OPENROUTER_API_KEY=sk-or-... OPENROUTER_MODEL=google/gemini-2.0-flash-001

# apps/api (server-side)
# Own Postgres, e.g. from docker-compose.dev.yml: postgresql://postgres:postgres@localhost:5446/postgres
DATABASE_URL=
# Used to verify the Supabase-issued JWT sent by apps/vocab's silent/anonymous login.
# Local Supabase CLI default: super-secret-jwt-token-with-at-least-32-characters-long
# Production: Supabase dashboard -> Settings -> API -> JWT Secret
SUPABASE_JWT_SECRET=

